{
  "expo": {
    "name": "Walk Tracker",
    "slug": "walktracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "walktracker",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/assets/images/logo-icon.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.walktracker.app",
      "infoPlist": {
        "NSMotionUsageDescription": "Walk Tracker uses motion data to count your steps automatically."
      }
    },
    "android": {
      "package": "com.walktracker.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/assets/images/logo-adaptive.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACTIVITY_RECOGNITION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_HEALTH",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/assets/images/logo-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/assets/images/logo-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49120979-ecff-498e-b88d-454b27c8cb15"
      }
    },
    "owner": "amitanand1212"
  }
}
